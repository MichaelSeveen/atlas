{
  "name": "@atlas/web",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "bun build ./src/main.tsx --outdir ./dist --target browser --minify",
    "lint": "bun run typecheck",
