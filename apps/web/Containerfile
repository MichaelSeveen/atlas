FROM docker.io/oven/bun:1.3.14-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0 AS build
WORKDIR /app
COPY package.json bun.lock bunfig.toml ./
RUN bun install --frozen-lockfile
COPY public ./public
COPY src ./src
RUN bun run build

FROM docker.io/library/alpine:3.23.5@sha256:1beb0dc0a51de7ff38e3b5274078a2e0b81113ba5c7535e1a03d5913a5edbda3
ARG SOURCE_REVISION=development
LABEL org.opencontainers.image.source="https://github.com/MichaelSeveen/atlas" \
      org.opencontainers.image.revision="${SOURCE_REVISION}" \
      org.opencontainers.image.title="Atlas feature-free React route shells"
RUN apk add --no-cache libgcc=15.2.0-r2 libstdc++=15.2.0-r2 \
    && addgroup -S -g 1000 bun \
    && adduser -S -D -H -u 1000 -G bun bun
WORKDIR /app
COPY --from=build /usr/local/bin/bun /usr/local/bin/bun
COPY --from=build --chown=bun:bun /app/package.json ./package.json
COPY --from=build --chown=bun:bun /app/public ./public
COPY --from=build --chown=bun:bun /app/src/server.ts ./src/server.ts
COPY --from=build --chown=bun:bun /app/src/server-lifecycle.ts ./src/server-lifecycle.ts
COPY --from=build --chown=bun:bun /app/dist ./dist
USER bun
EXPOSE 3000
CMD ["bun", "run", "./src/server.ts"]
